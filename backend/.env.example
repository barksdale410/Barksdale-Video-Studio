# Application
APP_NAME="Barksdale Video Studio"
APP_VERSION="2.0.0"
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/barksdale

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production

# External APIs
# Get your TMDB API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# Get your OpenAI API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Get your Replicate API token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token

# AWS S3 (optional - for video storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=barksdale-videos
AWS_REGION=us-east-1

# Rate Limiting
FREE_TIER_GENERATIONS_PER_DAY=5
PREMIUM_TIER_GENERATIONS_PER_DAY=-1
